# ===================================
# Pricing Product Endpoints
# ===================================

### @name create_product_laptop_new
POST http://localhost:8080/api/v1/pricing/products
Content-Type: application/json

{
  "sku": "LAPTOP-NEW-001",
  "name": "Ultra Thin Pro Laptop",
  "description": "Latest generation ultra-thin professional laptop with advanced graphics",
  "base_price": 2499.99
}

###

### @name create_product_phone_premium
POST http://localhost:8080/api/v1/pricing/products
Content-Type: application/json

{
  "sku": "PHONE-PREMIUM-001",
  "name": "Flagship Ultra Max",
  "description": "Premium flagship smartphone with all latest features",
  "base_price": 1299.99
}

###

### @name get_product_by_sku
GET http://localhost:8080/api/v1/pricing/products/LAPTOP-001
Accept: application/json

###

### @name patch_product_details
PATCH http://localhost:8080/api/v1/pricing/products/LAPTOP-001
Content-Type: application/json

{
  "name": "Premium Pro Laptop - Updated Edition",
  "description": "High-performance laptop for professionals with latest specs",
  "base_price": 1399.99
}

###

### @name patch_product_price_only
PATCH http://localhost:8080/api/v1/pricing/products/PHONE-001
Content-Type: application/json

{
  "base_price": 1099.99
}

###

# ===================================
# Pricing Endpoints
# ===================================

### @name post_price_update_laptop
POST http://localhost:8080/api/v1/pricing/prices
Content-Type: application/json

{
  "product_sku": "LAPTOP-001",
  "amount": 1199.99,
  "currency": "USD"
}

###

### @name post_price_update_phone
POST http://localhost:8080/api/v1/pricing/prices
Content-Type: application/json

{
  "product_sku": "PHONE-001",
  "amount": 899.99,
  "currency": "USD"
}

###

### @name post_price_update_monitor
POST http://localhost:8080/api/v1/pricing/prices
Content-Type: application/json

{
  "product_sku": "MONITOR-001",
  "amount": 449.99,
  "currency": "USD"
}

###

### @name get_prices_laptop
GET http://localhost:8080/api/v1/pricing/products/LAPTOP-001/prices

###

### @name get_prices_phone
GET http://localhost:8080/api/v1/pricing/products/PHONE-001/prices

###

### @name get_prices_monitor
GET http://localhost:8080/api/v1/pricing/products/MONITOR-001/prices

###


### @name get_quote_laptop_stress
GET http://localhost:8080/api/v1/pricing/products/LAPTOP-001/quote?quantity=430&channel=WEB

###


### @name get_segment_quote_ok
GET http://localhost:8080/api/v1/pricing/products/LAPTOP-001/quote/segment?segment=vip

###

### @name get_segment_quote_500
GET http://localhost:8080/api/v1/pricing/products/LAPTOP-001/quote/segment?segment=flash

###
